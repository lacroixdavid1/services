{
  "TCP": {
    "443": {
      "HTTPS": true
    },
    "80": {
      "HTTP": true
    }
  },
  "Web": {
    "${TS_CERT_DOMAIN}:80": {
      "Handlers": {
        "/": {
          "Proxy": "http://trilium-nginx:8080"
        }
      }
    },
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/": {
          "Proxy": "http://trilium-nginx:8081"
        }
      }
    }
  }
}
