{
	admin :2019 {

	}
	metrics {
		per_host
	}
}

emby.{$PUBLIC_DOMAIN} {
	reverse_proxy http://emby:8096
}

calibre.{$PUBLIC_DOMAIN} {
	handle /kobo/* {
		reverse_proxy http://calibre-web-app:8083
	}
	respond 404
}

static.{$PUBLIC_DOMAIN} {
	header X-Robots-Tag "noindex, nofollow"
	handle /robots.txt {
		respond "User-agent: *\nDisallow: /" 200
	}
	root * /static
	file_server
}

