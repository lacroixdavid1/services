files.{$PUBLIC_DOMAIN} {
	header X-Robots-Tag "noindex, nofollow"
	handle /robots.txt {
		respond "User-agent: *\nDisallow: /" 200
	}
	root * /files
	file_server
}

n8n.{$PUBLIC_DOMAIN} {
	handle /webhook/* {
		reverse_proxy http://n8n-nginx:8081
	}
	handle /webhook-test/* {
		reverse_proxy http://n8n-nginx:8081
	}
	respond 404
}

:443, :80 {
	respond "" 204
